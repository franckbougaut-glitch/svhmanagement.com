FLASK_SECRET_KEY=change-this-secret-key
PORT=5001
FLASK_DEBUG=1
SESSION_COOKIE_SECURE=0
TRUST_PROXY=0
MAX_CV_FILE_SIZE_MB=10
SVH_DATA_DIR=./data
SVH_DRIVE_RESOURCES_FILE=./data/drive_resources.json

# Email notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_TIMEOUT_SEC=20
CONTACT_EMAIL_TO=contact@svhmanagement.fr
CONTACT_EMAIL_FROM=
EMAIL_NOTIFICATIONS_REQUIRED=0
